<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <!-- List View -->
        <record id="SAND_BILLING_receipt_list" model="ir.ui.view">
            <field name="name">sand.billing.receipt.list</field>
            <field name="model">sand.billing.receipt</field>
            <field name="arch" type="xml">
                <list string="Sand Billing Receipts">
                    <field name="receipt_id" />
                    <field name="order_id" />
                    <field name="trip_no" />
                    <field name="customer_name" />
                    <field name="sand_quantity" />
                    <field name="state" />
                    <field name="created_date" />
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="SAND_BILLING_receipt_form" model="ir.ui.view">
            <field name="name">sand.billing.receipt.form</field>
            <field name="model">sand.billing.receipt</field>
            <field name="arch" type="xml">
                <form string="Sand Billing Receipt">
                    <header>
                        <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_print_receipt" type="object" string="Generate Receipt" class="oe_highlight" />
                        <button name="action_reset_to_draft" type="object" string="Reset to Draft" />
                        <field name="state" widget="statusbar" />
                    </header>

                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="receipt_id" readonly="1" />
                            </h1>
                        </div>

                        <!-- QR Code and Main Info -->
                        <group>
                            <group string="Order Information">
                                <field name="order_id" />
                                <field name="trip_no" />
                                <field name="dispatch_id" readonly="1" />
                                <field name="dispatch_date" />
                                <field name="registration_date" />
                            </group>
                            <group>
                                <field name="qr_code" widget="image" nolabel="1" options="{'size': [120, 120]}" invisible="state == 'draft'"/>
                                <field name="company_id" invisible="1" />
                            </group>
                        </group>

                        <group>
                            <group string="Customer Details">
                                <field name="customer_name" />
                                <field name="customer_mobile" />
                            </group>
                            <group string="Sand Information">
                                <field name="sand_quantity" />
                                <field name="sand_supply_point" />
                            </group>
                        </group>

                        <group>
                            <group string="Driver Details">
                                <field name="driver_name" />
                                <field name="driver_phone" />
                                <field name="vehicle_no" />
                            </group>
                            <group string="Construction Info">
                                <field name="construction_name" />
                            </group>
                        </group>

                        <group string="Address Information">
                            <group>
                                <field name="address" placeholder="Delivery Address..." />
                            </group>
                            <group>
                                <field name="registration_address" placeholder="Registration Address..." />
                            </group>
                        </group>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="SAND_BILLING_receipt_search" model="ir.ui.view">
            <field name="name">sand.billing.receipt.search</field>
            <field name="model">sand.billing.receipt</field>
            <field name="arch" type="xml">
                <search string="Sand Billing Receipt">
                    <field name="receipt_id" />
                    <field name="order_id" />
                    <field name="trip_no" />
                    <field name="customer_name" />
                    <field name="driver_name" />
                    <field name="dispatch_id" />
                    <separator />
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]" />
                    <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]" />
                    <filter string="Printed" name="printed" domain="[('state', '=', 'printed')]" />
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_SAND_BILLING_receipt" model="ir.actions.act_window">
            <field name="name">Sand Billing Receipt</field>
            <field name="res_model">sand.billing.receipt</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first sand billing receipt here!
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem
            id="menu_SAND_BILLING_root"
            name="Sand Billing"
            sequence="1" />

        <menuitem
            id="menu_SAND_BILLING_receipt"
            name="Billing Receipts"
            action="action_SAND_BILLING_receipt"
            parent="menu_SAND_BILLING_root"
            sequence="1" />

</odoo>



