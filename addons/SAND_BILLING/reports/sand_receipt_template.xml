                .receipt-header { text-align: center; margin-bottom: 10px; }
                .receipt-header img { max-width: 60px; height: auto; }
                .receipt-header h3 { margin: 3px 0 0 0; font-size: 14px; font-weight: bold; }
                .receipt-header p { margin: 0; font-size: 10px; }
                .copy-title { text-align: center; margin-bottom: 10px; text-decoration: underline; font-weight: bold; font-size: 11px; }
                .receipt-details { font-size: 11px; line-height: 1.5; margin-bottom: 10px; }
                .receipt-details div { margin-bottom: 2px; }
                .separator { text-align: center; margin: 15px 0; font-size: 10px; line-height: 0.8; }
                .qr-section { text-align: center; margin: 10px 0; }
                .qr-section img { max-width: 120px; height: auto; }
                .coordinates { text-align: center; font-size: 10px; margin: 5px 0; }
