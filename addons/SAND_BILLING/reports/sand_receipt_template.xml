<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <template id="report_sand_receipt">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="SAND_BILLING.report_sand_receipt_document" />
                </t>
            </t>
        </template>

        <template id="report_sand_receipt_html">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="SAND_BILLING.report_sand_receipt_document_html" />
                </t>
            </t>
        </template>

        <!-- PDF Template - Simple Thermal Receipt Format -->
        <template id="report_sand_receipt_document">
            <t t-call="web.basic_layout">
                <div class="page" style="max-width: 80mm; margin: 0 auto; padding: 0; font-family: monospace; font-size: 9pt; line-height: 1.3;">

                    <!-- CONSUMER COPY -->
                    <div style="margin-bottom: 0;">
                        <!-- Header -->
                        <div style="text-align: center; margin-bottom: 2mm;">
                            <t t-if="doc.company_id.logo">
                                <img t-attf-src="data:image/png;base64,{{doc.company_id.logo}}"
                                     style="max-width: 20mm; height: auto;" alt="Company Logo"/>
                            </t>
                            <div style="margin-top: 0.5mm; font-size: 10pt; font-weight: bold;">
                                <t t-out="doc.company_id.name" />
                            </div>
                            <div style="font-size: 8pt;">MANAGEMENT SYSTEM</div>
                        </div>

                        <!-- Copy Type -->
                        <div style="text-align: center; margin-bottom: 2mm; text-decoration: underline; font-weight: bold; font-size: 9pt;">
                            Consumer Copy
                        </div>

                        <!-- Details -->
                        <div style="font-size: 8pt; margin-bottom: 2mm; line-height: 1.5;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Order ID</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.order_id" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Trip No</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.trip_no" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Customer Name</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.customer_name" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Customer Mobile</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.customer_mobile" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Sand Quantity</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="'{:.1f}'.format(doc.sand_quantity)" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Supply Point</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.sand_supply_point" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Dispatch Date</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.dispatch_date.strftime('%d-%m-%Y %H:%M')" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Driver Name</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.driver_name" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Driver Mobile</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.driver_phone" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Vehicle No</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.vehicle_no" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Address</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.address" /></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Separator Line -->
                    <div style="text-align: center; margin: 3mm 0; font-size: 8pt; line-height: 1;">
                        <div>- - - - - - - - - - - - - - - - - - - - - - - - - - - -</div>
                        <div>- - - - - - - - - - - - - - - - - - - - - - - - - - - -</div>
                    </div>

                    <!-- DRIVER COPY -->
                    <div>
                        <!-- Header -->
                        <div style="text-align: center; margin-bottom: 2mm;">
                            <t t-if="doc.company_id.logo">
                                <img t-attf-src="data:image/png;base64,{{doc.company_id.logo}}"
                                     style="max-width: 20mm; height: auto;" alt="Company Logo"/>
                            </t>
                            <div style="margin-top: 0.5mm; font-size: 10pt; font-weight: bold;">
                                <t t-out="doc.company_id.name" />
                            </div>
                            <div style="font-size: 8pt;">MANAGEMENT SYSTEM</div>
                        </div>

                        <!-- Copy Type -->
                        <div style="text-align: center; margin-bottom: 2mm; text-decoration: underline; font-weight: bold; font-size: 9pt;">
                            Driver Copy
                        </div>

                        <!-- Details -->
                        <div style="font-size: 8pt; margin-bottom: 2mm; line-height: 1.5;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Order ID</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.order_id" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Trip No</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.trip_no" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Customer Name</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.customer_name" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Customer Mobile</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.customer_mobile" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Sand Quantity</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="'{:.1f}'.format(doc.sand_quantity)" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Supply Point</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.sand_supply_point" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Dispatch Date</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.dispatch_date.strftime('%d-%m-%Y %H:%M')" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Driver Name</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.driver_name" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Driver Mobile</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.driver_phone" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Vehicle No</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.vehicle_no" /></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1mm; font-weight: bold;"><strong>Address</strong></td>
                                    <td style="padding: 1mm; text-align: right;"><t t-out="doc.address" /></td>
                                </tr>
                            </table>
                        </div>

                        <!-- QR Code -->
                        <div style="text-align: center; margin: 2mm 0;">
                            <img t-if="doc.qr_code" t-attf-src="data:image/png;base64,{{doc.qr_code}}"
                                 style="max-width: 45mm; height: auto;" alt="QR Code"/>
                        </div>

                        <!-- Thank You -->
                        <div style="text-align: center; font-weight: bold; font-size: 9pt;">
                            Thank You
                        </div>
                    </div>
                </div>
            </t>
        </template>

